# Switchyard environment configuration
# Copy to .env and adjust as needed.
# All fields are optional — sensible defaults apply for local Docker.

# Path to YAML config file (required unless passed at startup)
# Relative paths are resolved from the directory containing .env
# SWITCHYARD_CONFIG_PATH=config.yaml

# Docker API endpoint. Set for remote Docker (SSH tunnel, etc.).
# Example: tcp://127.0.0.1:2375
# SWITCHYARD_DOCKER_HOST=

# Hostname/IP for reaching published container ports from the control plane.
# For local Docker, leave as localhost.
# For remote Docker, set to the remote host or tunnel address.
# SWITCHYARD_BACKEND_HOST=localhost

# URL scheme for backend HTTP calls (http or https).
# SWITCHYARD_BACKEND_SCHEME=http

# Docker network used by backend containers.
# SWITCHYARD_DOCKER_NETWORK=model-runtime

# Health check interval in seconds.
# SWITCHYARD_HEALTH_INTERVAL_SECONDS=2

# Startup health timeout in seconds. Model stays in "loading"
# until this timeout expires before transitioning to "error".
# SWITCHYARD_HEALTH_TIMEOUT_SECONDS=300

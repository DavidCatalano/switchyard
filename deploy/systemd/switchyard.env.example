# Switchyard process-local bootstrap settings.
# Copy to /etc/switchyard/switchyard.env and edit for the deployment host.

SWITCHYARD_CONFIG_PATH=/etc/switchyard/config.yaml
SWITCHYARD_LOG_LEVEL=info
SWITCHYARD_API_HOST=0.0.0.0
SWITCHYARD_API_PORT=8000
SWITCHYARD_ACTIVE_HOST=trainbox

# Leave unset when each host's docker_host is defined in config.yaml.
# Use only for a process-wide Docker host override.
# SWITCHYARD_DOCKER_HOST=

